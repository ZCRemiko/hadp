# Hadoop 闂嗗棛鍏㈤悳顖氼暔閸欐﹢鍣洪柊宥囩枂閺傚洣娆?# 鐞?docker-compose.yml 娑擃厽澧嶉張?Hadoop 鐎圭懓娅掗崗鍙橀煩
#
# 閸欐﹢鍣洪崨钘夋倳鐟欏嫬鍨? <SECTION>_CONF_<property_name>
#   CORE_CONF_*   -> 閸愭瑥鍙?core-site.xml
#   HDFS_CONF_*   -> 閸愭瑥鍙?hdfs-site.xml
#   YARN_CONF_*   -> 閸愭瑥鍙?yarn-site.xml
#   MAPRED_CONF_* -> 閸愭瑥鍙?mapred-site.xml
#
# 鐏炵偞鈧冩倳娑擃厾娈戦崣灞肩瑓閸掓帞鍤?__ 娴兼俺顫﹂弴鎸庡床娑?.閿涘牏鍋ｉ崣鍑ょ礆
# 鐏炵偞鈧冩倳娑擃厾娈戞稉澶夐嚋娑撳鍨濈痪?___ 娴兼俺顫﹂弴鎸庡床娑?-閿涘牊铆缁惧尅绱?# 鐏炵偞鈧冩倳娑擃厾娈戦崶娑楅嚋娑撳鍨濈痪?____ 娴兼俺顫﹂弴鎸庡床娑?@閿涘潊t缁楋箑褰块敍?# # HDFS 姒涙顓婚弬鍥︽缁崵绮洪崷鏉挎絻閿涙艾鎲＄拠澶嬪閺堝顓归幋椋庮伂 NameNode 閻ㄥ嫪缍呯純?CORE_CONF_fs_defaultFShdfs://namenode:9000
# 瀵偓閸?WebHDFS閿涘湩EST API 閺傜懓绱＄拋鍧楁６ HDFS閿?HDFS_CONF_dfs_webhdfs_enabled=true
# 閸忔娊妫撮弶鍐濡偓閺屻儻绱欏鈧崣鎴犲箚婢у喛绱濋弬閫涚┒濞村鐦敍?HDFS_CONF_dfs_permissions_enabled=false
# 閸忔娊妫?DataNode 濞夈劌鍞介弮鍓佹畱 IP 娑撶粯婧€閸氬秵鐗庢宀嬬礄Docker 缂冩垹绮堕悳顖氼暔韫囧懘娓堕敍?HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
# 瀵偓閸氼垱妫╄箛妤勪粵閸氬牞绱橫apReduce娴犺濮熼弮銉ョ箶闂嗗棔鑵戠€涙ê鍋嶉敍?YARN_CONF_yarn_log___aggregation___enable=true
# ResourceManager 閸︽澘娼?YARN_CONF_yarn_resourcemanager_hostname=resourcemanager
YARN_CONF_yarn_resourcemanager_address=resourcemanager:8032
YARN_CONF_yarn_resourcemanager_scheduler_address=resourcemanager:8030
YARN_CONF_yarn_resourcemanager_resource__tracker_address=resourcemanager:8031
# 娴ｈ法鏁?CapacityScheduler閿涘牆顔愰柌蹇氱殶鎼达箑娅掗敍?YARN_CONF_yarn_resourcemanager_scheduler_class=org.apache.hadoop.yarn.server.resourcemanager.scheduler.capacity.CapacityScheduler
# 閹稿洤鐣?MapReduce 娴ｈ法鏁?YARN 娴ｆ粈璐熺挧鍕爱缁狅紕鎮婇崳?MAPRED_CONF_mapreduce_framework_name=yarn
